# ----- Kafka -----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_SENSOR_RAW=sensor-raw
KAFKA_CONSUMER_GROUP_AQI=aqi-evaluator-group
KAFKA_CONSUMER_GROUP_RAW=raw-writer-group
KAFKA_CONSUMER_GROUP_LAKEHOUSE=lakehouse-writer-group

# ----- MongoDB -----
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=airquality

# ----- Mamba forecasting API -----
# Endpoint accepts full raw records (15 fields per row, 168 rows per sensor)
# and returns 12-hour pollutant forecasts. The backend does no preprocessing.
MAMBA_API_URL=http://mamba-predictor:8000/predict_raw
MAMBA_API_TIMEOUT_SECONDS=60

# ----- Forecast scheduler -----
FORECAST_WINDOW_SIZE=168
FORECAST_HORIZON_HOURS=12
FORECAST_SCHEDULER_INTERVAL_SECONDS=5

# ----- LLM (Groq today; OpenAI-compatible API) -----
# Swap providers by changing LLM_API_BASE_URL:
#   Groq:    https://api.groq.com/openai/v1
#   OpenAI:  https://api.openai.com/v1
#   Ollama:  http://localhost:11434/v1
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
LLM_API_BASE_URL=https://api.groq.com/openai/v1
LLM_TIMEOUT_SECONDS=30

# ----- Recommendation scheduler -----
RECOMMENDATION_SCHEDULER_INTERVAL_SECONDS=15

# ----- In-process scheduler (set true to skip the standalone scheduler procs) -----
ENABLE_IN_PROCESS_SCHEDULER=false

# ----- Alerts / notifications -----
# Lowest urgency that triggers a push (safe / caution / avoid / danger).
ALERT_URGENCY_THRESHOLD=avoid
ALERT_COOLDOWN_HOURS=1
ALERT_DEFAULT_LANGUAGE=fr
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
EXPO_PUSH_TIMEOUT_SECONDS=15

# ----- Chatbot -----
CHAT_HISTORY_WINDOW=10
CHAT_MAX_MESSAGES_PER_SESSION=200
RAG_TOP_K=5
# Set to true ONLY when running against MongoDB Atlas with a vector index.
USE_ATLAS_VECTOR_SEARCH=false
ATLAS_VECTOR_INDEX_NAME=knowledge_chunks_vector_index

# ----- Embeddings -----
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ----- Storage paths -----
LAKEHOUSE_PATH=./data/lakehouse
CSV_DATA_PATH=./data/raw_csv

# ----- Lakehouse writer -----
LAKEHOUSE_BATCH_SIZE=200
LAKEHOUSE_FLUSH_INTERVAL_SECONDS=30

# ----- Simulation -----
SIMULATION_TICK_SECONDS=5
# Comma-separated list. Leave empty to use all 38 sensors.
ACTIVE_SENSOR_IDS=
# When CSV rows run out, restart from row 0 (true) or stop (false).
PRODUCER_LOOP_ON_EOF=true

# ----- Recommendation reuse -----
RECOMMENDATION_REGEN_INTERVAL_HOURS=3

# ----- Auth -----
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
JWT_GUEST_TOKEN_EXPIRE_MINUTES=43200

# ----- Logging -----
LOG_LEVEL=INFO
